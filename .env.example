# gittr-mcp — copy to .env and load with your shell or dotenv tool (not loaded automatically by Node)

# Nostr signing for MCP / scripts: copy .nostr-keys.json.example → .nostr-keys.json and fill nsec (see README).
# Or set per-session: GITTR_TEST_NSEC / GITTR_TEST_PRIVKEY for test scripts only.

# Bridge / UI API origin (Next.js routes)
BRIDGE_URL=https://gittr.space

# Default relays for Nostr publish (comma-separated wss://)
# NIP34_RELAYS=wss://relay.ngit.dev

# Happy-path script: set to 1 only when you intend to create a real repo + issue
# HAPPY_PATH_LIVE=1

# Test identity (local only — never commit real keys)
# GITTR_TEST_NSEC=
# GITTR_TEST_PRIVKEY=
# GITTR_TEST_RELAYS=wss://relay.ngit.dev
# GITTR_TEST_REPO=my-test-repo

# Bounty invoice step (optional; same as gittr Settings → Account LNbits)
# GITTR_LNBITS_URL=
# GITTR_LNBITS_ADMIN_KEY=
# GITTR_BOUNTY_SATS=10

# HAPPY_PATH_SKIP_BOUNTY=1
